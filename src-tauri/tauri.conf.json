{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Athu Music D",
  "version": "0.1.1",
  "identifier": "com.athu.music",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Athu Music D",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "appimage",
      "rpm",
      "deb"
    ],
    "linux": {
      "category": "Audio",
      "shortDescription": "Premium Material You music player",
      "longDescription": "Athu Music D is a high-performance desktop music player built for speed and beauty, featuring dynamic Material You theming and smart metadata scraping."
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
